# ============================================
# CONFIGURACIÓN DE LICENCIAS
# ============================================

# Clave secreta para encriptación de licencias
# IMPORTANTE: Cambia esto en producción y guárdalo de forma segura
# Genera una clave aleatoria fuerte de al menos 32 caracteres
LICENSE_SECRET_KEY=TecnovariedadesDS2024SecretKeyChangeThis

# Clave para generar licencias (solo admin)
# IMPORTANTE: Solo tú debes tener acceso a esta clave
# Úsala en el endpoint /api/license/generate
ADMIN_SECRET_KEY=AdminSecretKeyForLicenseGenerationChangeThis

# ============================================
# NOTAS IMPORTANTES
# ============================================
# 
# 1. NUNCA compartas estas claves con nadie
# 2. NUNCA las subas a GitHub o repositorios públicos
# 3. Usa claves diferentes para desarrollo y producción
# 4. Guarda las claves de producción en un gestor de contraseñas
# 5. Si las claves se comprometen, genera nuevas inmediatamente
#
# Para generar claves seguras, usa:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
