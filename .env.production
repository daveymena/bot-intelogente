# 🚀 CONFIGURACIÓN DE PRODUCCIÓN - EASYPANEL
# Copia este archivo y configura tus valores reales

# ===== CONFIGURACIÓN GENERAL =====
NODE_ENV=production
PORT=3000
NEXT_PUBLIC_APP_URL=https://tu-dominio.easypanel.host

# ===== INTELIGENCIA ARTIFICIAL =====
# Groq API (Ultra rápido y preciso)
GROQ_API_KEY=tu_groq_api_key_aqui
GROQ_MODEL=llama-3.1-8b-instant
GROQ_FALLBACK_MODELS=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=350
GROQ_TIMEOUT=5000

# OpenRouter (Acceso a múltiples modelos)
OPENROUTER_API_KEY=tu_openrouter_api_key_aqui
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# Ollama (IA local en tu servidor)
OLLAMA_BASE_URL=https://tu-ollama.easypanel.host
OLLAMA_MODEL=gemma:2b
OLLAMA_ENABLED=true
OLLAMA_TIMEOUT=10000
OLLAMA_MAX_TOKENS=300

# Configuración del Sistema de Fallback
AI_PROVIDER=ollama
DEFAULT_AI_PROVIDER=ollama
AI_FALLBACK_ENABLED=true
AI_FALLBACK_ORDER=ollama,groq,openrouter

# Sistema de Razonamiento Avanzado (IMPORTANTE)
AI_USE_REASONING=true

# ===== WHATSAPP CONFIGURACIÓN =====
WHATSAPP_PROVIDER=baileys

# Sistema de Reconexión
HEARTBEAT_INTERVAL=10000
RECONNECT_ATTEMPTS_MAX=100
RECONNECT_DELAY_BASE=500
RECONNECT_DELAY_MAX=60000

# Sistema de salud avanzado
MAX_CONSECUTIVE_FAILURES=5
CONNECTION_HEALTH_THRESHOLD=80
ENABLE_CONNECTION_MONITOR=true

# Estrategias de reconexión
ENABLE_SESSION_RECOVERY=true
ENABLE_SOFT_RESET=true
ENABLE_AGGRESSIVE_RESET=true
ENABLE_CONSERVATIVE_MODE=true

# Configuración de Puppeteer optimizada
PUPPETEER_HEADLESS=true
PUPPETEER_SANDBOX=false
PUPPETEER_SHM_USAGE=false
PUPPETEER_GPU=false
PUPPETEER_WEB_SECURITY=false

# Configuración de sesiones
SESSION_PATH=./whatsapp-sessions
SESSION_BACKUP_COUNT=3
SESSION_RECOVERY_TIMEOUT=30000

# ===== AUTENTICACIÓN Y SEGURIDAD =====
NEXTAUTH_SECRET="CAMBIAR_ESTE_SECRET_EN_PRODUCCION_usar_openssl_rand_base64_32"
NEXTAUTH_URL="https://tu-dominio.easypanel.host"
JWT_SECRET="CAMBIAR_ESTE_JWT_SECRET_EN_PRODUCCION"

# ===== BASE DE DATOS =====
# PostgreSQL en Easypanel
DATABASE_PROVIDER=postgresql
DATABASE_URL="postgresql://postgres:TU_PASSWORD@postgres:5432/botwhatsapp"

# ===== SISTEMA DE EMAILS (RESEND) =====
# IMPORTANTE: Configura esto para que funcione el registro de usuarios
RESEND_API_KEY=tu_resend_api_key_aqui
RESEND_FROM_EMAIL=onboarding@resend.dev
EMAIL_FROM=Tecnovariedades D&S <onboarding@resend.dev>

# Para usar tu dominio personalizado:
# 1. Verifica tu dominio en Resend
# 2. Actualiza: RESEND_FROM_EMAIL=noreply@tudominio.com

# ===== CONFIGURACIÓN DE NEGOCIO =====
BUSINESS_NAME="Tecnovariedades D&S"
BUSINESS_ADDRESS="Colombia"
BOT_NAME=Tecnovariedades D&S Bot
BOT_PHONE=+57 300 556 0186
BUSINESS_PHONE=+57 300 556 0186
BUSINESS_EMAIL=deinermena25@gmail.com
BOT_LANGUAGE=es

# ===== DROPI INTEGRATION =====
DROPI_AGENT_TOKEN=tu_dropi_token_aqui
DROPI_API_URL=https://app.dropi.co/api/v1
DROPI_ENABLED=true

# Configuración de precios dropshipping
DROPSHIPPING_SHIPPING_MIN=15000
DROPSHIPPING_SHIPPING_MAX=20000
DROPSHIPPING_PROFIT_MIN=20000
DROPSHIPPING_PROFIT_MAX=30000

# Número de WhatsApp para catálogo público
NEXT_PUBLIC_WHATSAPP_NUMBER=573005560186

# ===== CARACTERÍSTICAS HABILITADAS =====
PHOTOS_ENABLED=true
AUDIO_ENABLED=true
HOT_RELOAD_ENABLED=true
AI_ENABLED=true
DYNAMIC_PRICING_ENABLED=true
WEB_ENABLED=true
WEB_AUTH=false

# ===== MÉTODOS DE PAGO =====
# Nequi
NEQUI_NUMBER=3005560186

# Daviplata
DAVIPLATA_NUMBER=3005560186

# Bancolombia
BANK_NAME=Bancolombia
BANK_ACCOUNT_TYPE=Ahorros
BANK_ACCOUNT_NUMBER=12345678901
BANK_ACCOUNT_HOLDER=Tu Nombre Completo

# Mercado Pago
MERCADO_PAGO_PUBLIC_KEY=tu_public_key
MERCADO_PAGO_ACCESS_TOKEN=tu_access_token
MERCADO_PAGO_CLIENT_ID=tu_client_id

# PayPal
PAYPAL_CLIENT_ID=tu_paypal_client_id
PAYPAL_CLIENT_SECRET=tu_paypal_secret
PAYPAL_MODE=live
PAYPAL_API_URL=https://api-m.paypal.com

# Efectivo
CASH_ON_DELIVERY_ENABLED=true
DELIVERY_ZONES=Bogotá,Medellín,Cali

# ===== ADMIN =====
ADMIN_EMAIL="tu_email@gmail.com"
ADMIN_PASSWORD="tu_password_seguro"

# ===== LOGGING =====
LOG_LEVEL=info
LOG_CONNECTION_EVENTS=true
LOG_HEARTBEAT_EVENTS=true
LOG_RECONNECTION_EVENTS=true

# ===== RENDIMIENTO =====
MAX_CONCURRENT_CONNECTIONS=1
CONNECTION_TIMEOUT=60000
MESSAGE_QUEUE_SIZE=100
