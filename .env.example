# 🤖 BOT SUPER INTELIGENTE - Configuración de Ejemplo
# Copia este archivo a .env y completa con tus valores reales

# ===== CONFIGURACIÓN GENERAL =====
NODE_ENV=production
PORT=4000
NEXT_PUBLIC_APP_URL=https://tu-dominio.com

# ===== INTELIGENCIA ARTIFICIAL =====
# Groq API (Principal - Ultra rápido)
GROQ_API_KEY=tu_groq_api_key_aqui
GROQ_MODEL=llama-3.1-8b-instant
GROQ_MAX_TOKENS=300
GROQ_TIMEOUT=60000

# Rotación de API keys de Groq (opcional - para evitar rate limits)
GROQ_API_KEY_2=tu_segunda_key_aqui
GROQ_API_KEY_3=tu_tercera_key_aqui
GROQ_API_KEY_4=
GROQ_API_KEY_5=
GROQ_API_KEY_6=
GROQ_API_KEY_7=
GROQ_API_KEY_8=

# Ollama (Fallback - Gratis e ilimitado)
OLLAMA_BASE_URL=https://tu-ollama-url.easypanel.host
OLLAMA_MODEL=gemma:2b
OLLAMA_ENABLED=true
OLLAMA_TIMEOUT=60000
OLLAMA_MAX_TOKENS=500

# Sistema de IA
AI_PROVIDER=groq
DEFAULT_AI_PROVIDER=groq
AI_FALLBACK_ENABLED=true
AI_USE_REASONING=true

# ===== BASE DE DATOS =====
DATABASE_PROVIDER=postgresql
DATABASE_URL="postgresql://usuario:password@host:5432/database"

# ===== AUTENTICACIÓN =====
NEXTAUTH_SECRET="genera-un-secret-aleatorio-aqui"
NEXTAUTH_URL="https://tu-dominio.com"
JWT_SECRET="genera-otro-secret-aleatorio"

# ===== WHATSAPP =====
WHATSAPP_PROVIDER=baileys
HEARTBEAT_INTERVAL=10000
RECONNECT_ATTEMPTS_MAX=100

# ===== NEGOCIO =====
BUSINESS_NAME="Tu Negocio"
BUSINESS_PHONE=+57_TU_NUMERO
BUSINESS_EMAIL=tu@email.com
BOT_LANGUAGE=es

# ===== MÉTODOS DE PAGO =====
# Nequi/Daviplata
NEQUI_NUMBER=TU_NUMERO
DAVIPLATA_NUMBER=TU_NUMERO

# MercadoPago
MERCADO_PAGO_PUBLIC_KEY=tu_public_key
MERCADO_PAGO_ACCESS_TOKEN=tu_access_token
MERCADO_PAGO_CLIENT_ID=tu_client_id

# PayPal
PAYPAL_CLIENT_ID=tu_paypal_client_id
PAYPAL_CLIENT_SECRET=tu_paypal_secret
PAYPAL_MODE=live
PAYPAL_API_URL=https://api-m.paypal.com

# Banco
BANK_NAME=Tu_Banco
BANK_ACCOUNT_NUMBER=TU_CUENTA
BANK_ACCOUNT_HOLDER=Tu_Nombre

# ===== EMAIL =====
RESEND_API_KEY=tu_resend_api_key
RESEND_FROM_EMAIL=noreply@tudominio.com
EMAIL_FROM=Tu Negocio <noreply@tudominio.com>

# Gmail OAuth (alternativa)
GMAIL_USER=tu@gmail.com
GMAIL_CLIENT_ID=tu_client_id
GMAIL_CLIENT_SECRET=tu_client_secret
GMAIL_REFRESH_TOKEN=tu_refresh_token

# ===== DROPI INTEGRATION =====
DROPI_AGENT_TOKEN=tu_dropi_token
DROPI_API_URL=https://app.dropi.co/api/v1
DROPI_ENABLED=true

# ===== ADMIN =====
ADMIN_EMAIL="admin@tudominio.com"
ADMIN_PASSWORD="cambia_este_password"

# ===== WHATSAPP PÚBLICO =====
NEXT_PUBLIC_WHATSAPP_NUMBER=57TU_NUMERO_SIN_ESPACIOS
