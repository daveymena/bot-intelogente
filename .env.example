# 🤖 CONFIGURACIÓN: GROQ + OLLAMA ACTIVOS
# Sistema conversacional con fallback automático y rotación de APIs

# ===== GROQ - ACTIVADO (Primario) =====
# Rotación automática de APIs cuando se alcanza el límite
GROQ_API_KEY=tu_groq_api_key_aqui
GROQ_API_KEY_2=tu_groq_api_key_2_aqui
GROQ_API_KEY_6=tu_groq_api_key_6_aqui
GROQ_ENABLED=true
GROQ_MODEL=llama-3.1-8b-instant
GROQ_FALLBACK_MODELS=llama-3.1-8b-instant,gemma2-9b-it
GROQ_MAX_TOKENS=300
GROQ_TIMEOUT=60000

# ===== OLLAMA - ACTIVADO (Fallback cuando Groq falla) =====
OLLAMA_ENABLED=true
OLLAMA_BASE_URL=https://tu-ollama-url.easypanel.host
OLLAMA_MODEL=gemma:2b
OLLAMA_TIMEOUT=60000
OLLAMA_MAX_TOKENS=500

# ===== OTRAS IAS - DESACTIVADAS =====
OPENAI_API_KEY=
OPENAI_ENABLED=false
CLAUDE_API_KEY=
CLAUDE_ENABLED=false
GEMINI_API_KEY=
GEMINI_ENABLED=false
MISTRAL_API_KEY=
MISTRAL_ENABLED=false
OPENROUTER_API_KEY=
OPENROUTER_ENABLED=false

# ===== CONFIGURACIÓN DE IA =====
AI_PROVIDER=groq
DEFAULT_AI_PROVIDER=groq
AI_FALLBACK_ENABLED=true
AI_USE_REASONING=true

# ===== CONFIGURACIÓN DE IA LOCAL (Desactivada - usando Groq/Ollama) =====
LOCAL_AI_ENABLED=false
LOCAL_AI_MODEL_PATH=./data/local-ai-model.json
LOCAL_AI_TRAINING_PATH=./data/training-data.json
LOCAL_AI_CACHE_ENABLED=false
LOCAL_AI_CACHE_TTL=3600000

# ===== FOTOS INTELIGENTES =====
SMART_PHOTOS_ENABLED=true
SMART_PHOTOS_MAX_PER_PRODUCT=3
SMART_PHOTOS_TEMP_DIR=./temp-images
SMART_PHOTOS_CLEANUP_INTERVAL=86400000

# ===== LINKS DE PAGO DINÁMICO =====
DYNAMIC_PAYMENT_LINKS_ENABLED=true
PAYMENT_LINK_EXPIRY_MINUTES=120
PAYMENT_LINK_TOKEN_SECRET=genera-un-secret-aleatorio-aqui

# ===== WHATSAPP WEB ESTABLE =====
WHATSAPP_PROVIDER=baileys
HEARTBEAT_INTERVAL=15000
RECONNECT_ATTEMPTS_MAX=50
RECONNECT_DELAY_BASE=1000
RECONNECT_DELAY_MAX=30000
ENABLE_CONNECTION_MONITOR=true
CONNECTION_HEALTH_CHECK_INTERVAL=30000
CONNECTION_HEALTH_THRESHOLD=80

# ===== BASE DE DATOS =====
DATABASE_PROVIDER=postgresql
DATABASE_URL="postgresql://usuario:password@host:5432/database"

# ===== CONFIGURACIÓN GENERAL =====
NODE_ENV=development
PORT=4000
NEXT_PUBLIC_APP_URL=http://localhost:4000

# ===== AUTENTICACIÓN =====
NEXTAUTH_SECRET="genera-un-secret-aleatorio-aqui"
NEXTAUTH_URL="http://localhost:4000"
JWT_SECRET="genera-otro-secret-aleatorio-aqui"

# ===== CONFIGURACIÓN DE NEGOCIO =====
BUSINESS_NAME="Tu Negocio"
BUSINESS_ADDRESS="Tu País"
BOT_NAME=Tu Bot
BOT_PHONE=+57 300 000 0000
BUSINESS_PHONE=+57 300 000 0000
BUSINESS_EMAIL=tu-email@gmail.com
BOT_LANGUAGE=es

# ===== MÉTODOS DE PAGO =====
NEQUI_NUMBER=3000000000
DAVIPLATA_NUMBER=3000000000
MERCADO_PAGO_PUBLIC_KEY=tu_mercadopago_public_key
MERCADO_PAGO_ACCESS_TOKEN=tu_mercadopago_access_token
MERCADO_PAGO_CLIENT_ID=tu_mercadopago_client_id

# ===== PAYPAL - LINKS DINÁMICOS =====
PAYPAL_CLIENT_ID=tu_paypal_client_id
PAYPAL_CLIENT_SECRET=tu_paypal_client_secret
PAYPAL_MODE=live
PAYPAL_API_URL=https://api-m.paypal.com
COP_TO_USD_RATE=4000

# ===== CARACTERÍSTICAS =====
PHOTOS_ENABLED=true
AUDIO_ENABLED=false
VOICE_ENABLED=false
HOT_RELOAD_ENABLED=true
AI_ENABLED=true
DYNAMIC_PRICING_ENABLED=true
WEB_ENABLED=true
WEB_AUTH=false

# ===== LOGGING =====
LOG_LEVEL=info
LOG_CONNECTION_EVENTS=true
LOG_HEARTBEAT_EVENTS=false
LOG_RECONNECTION_EVENTS=true

# ===== RENDIMIENTO =====
MAX_CONCURRENT_CONNECTIONS=1
CONNECTION_TIMEOUT=60000
MESSAGE_QUEUE_SIZE=100
